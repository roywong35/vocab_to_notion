{
  "manifest_version": 3,
  "name": "Vocab to Notion",
  "version": "1.0",
  "description": "Highlight a word and add it to your Notion vocabulary list.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.notion.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vocab to Notion"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
