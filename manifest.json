{
  "manifest_version": 3,
  "name": "Vocab to Notion",
  "version": "1.0",
  "description": "Highlight a word and add it to your Notion vocabulary list.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://api.notion.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vocab to Notion"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
